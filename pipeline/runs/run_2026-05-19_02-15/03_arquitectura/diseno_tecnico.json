      ]
    },
    {
      "nombre": "catalog",
      "proposito": "Gestionar catálogo de barcos, categorías, puertos, fabricantes, búsqueda, filtros y ficha de barco.",
      "archivos_principales": [
        "catalog/models.py",
        "catalog/views.py",
