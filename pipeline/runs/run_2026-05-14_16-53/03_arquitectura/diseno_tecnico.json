  "modelos": [
    {
      "nombre": "Categoria",
      "app": "catalog",
      "campos": [
        "nombre:CharField(max_length=120, unique=True)",
        "descripcion:TextField(blank=True)"
      ]
    },
    {
      "nombre": "Puerto",
      "app": "catalog",
